<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Sample_MAUI.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Spacing="25"
            Padding="30"
            VerticalOptions="Center">

            <Entry x:Name="EntryFirst" Placeholder="First Name" TextChanged="EntryFirst_TextChanged"/>
            <Entry x:Name="EntryLast" Placeholder="Last Name" TextChanged="EntryLast_TextChanged"/>

            <Label x:Name="LabelFullName"/>

            <Button
                x:Name="ButtonTest"
                Text="Click Me"
                HorizontalOptions="Center"
                Clicked="Button_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
